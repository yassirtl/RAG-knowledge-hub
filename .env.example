# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=knowledge_hub

# ── Ingestion ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_PDF_SIZE_MB=20
UPLOAD_DIR=./uploads

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=5
SCORE_THRESHOLD=0.35

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO
